{
  "openapi": "3.0.1",
  "info": {
    "title": "RelayApiStack",
    "description": "Relay's serverless front door (the M11 API, extended at Module 13 with the user-feedback route). The async support-ticket API: POST a ticket (202 + ticket_id), poll GET for the TicketRecord, POST an approval to realize the Module 8 human-in-the-loop refund gate, and POST a 1-5 feedback rating on the answer (skill 5.1.3). This document is the OpenAPI (oas30) export of the deployed Amazon API Gateway REST API — the contract any Amplify / OpenAPI client integrates against. Regenerate it from the deployed stack with `aws apigateway get-export --rest-api-id <id> --stage-name prod --export-type oas30 --accepts application/json openapi.json`.",
    "version": "2026-06-14T00:00:00Z"
  },
  "servers": [
    {
      "url": "https://{restApiId}.execute-api.{region}.amazonaws.com/{basePath}",
      "variables": {
        "restApiId": {
          "default": "abc123def4",
          "description": "The deployed REST API id (CloudFormation output ApiUrl)."
        },
        "region": {
          "default": "us-east-1"
        },
        "basePath": {
          "default": "prod"
        }
      }
    }
  ],
  "paths": {
    "/tickets": {
      "post": {
        "operationId": "createTicket",
        "summary": "Accept a CloudCart support ticket (async).",
        "description": "Validate the body into the frozen Ticket schema, persist TicketRecord{status:received} to relay-tickets, enqueue the agent job on SQS, and return 202 Accepted with the ticket_id. The work is ACCEPTED, not done — poll GET /tickets/{ticket_id} for the final status. No foundation-model call happens here; generation runs in the worker through the unchanged agent.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTicketRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted. The ticket is queued for processing.",
            "headers": {
              "Access-Control-Allow-Origin": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTicketResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — the payload failed the JSON-Schema request model or the business contract (e.g. an empty customer_message, an invalid channel).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Could not accept the ticket (e.g. the work queue is unavailable).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "x-amazon-apigateway-integration": {
          "type": "aws_proxy",
          "httpMethod": "POST",
          "passthroughBehavior": "when_no_match",
          "uri": "arn:aws:apigateway:us-east-1:lambda:path/2015-03-31/functions/arn:aws:lambda:us-east-1:123456789012:function:RelayApiStack-post/invocations"
        }
      }
    },
    "/tickets/{ticket_id}": {
      "get": {
        "operationId": "getTicket",
        "summary": "Read the persisted TicketRecord.",
        "description": "The poll side of the async pattern. Returns 200 + the full frozen TicketRecord (status lifecycle received -> triaged -> awaiting_approval -> answered / escalated / closed / failed), or a clean 404 when there is no such ticket — never an empty 200 a client would misread as 'still processing'.",
        "parameters": [
          {
            "name": "ticket_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The TicketRecord for this ticket_id.",
            "headers": {
              "Access-Control-Allow-Origin": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketRecord"
                }
              }
            }
          },
          "404": {
            "description": "No ticket with that id was found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Could not read the ticket.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "x-amazon-apigateway-integration": {
          "type": "aws_proxy",
          "httpMethod": "POST",
          "passthroughBehavior": "when_no_match",
          "uri": "arn:aws:apigateway:us-east-1:lambda:path/2015-03-31/functions/arn:aws:lambda:us-east-1:123456789012:function:RelayApiStack-get/invocations"
        }
      }
    },
    "/tickets/{ticket_id}/approve": {
      "post": {
        "operationId": "approveTicket",
        "summary": "Realize the Module 8 human-in-the-loop refund gate over HTTP.",
        "description": "A thin wrapper over relay.approve.approve(ticket_id, decision). approved=true executes the refund and moves status -> answered; approved=false abandons it and escalates (status -> escalated). Strict: `approved` MUST be a JSON boolean (a refund is money moving — no truthy coercion). 409 when the ticket is not awaiting approval (already decided / wrong status). No foundation-model call.",
        "parameters": [
          {
            "name": "ticket_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated TicketRecord after the approve / reject decision.",
            "headers": {
              "Access-Control-Allow-Origin": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketRecord"
                }
              }
            }
          },
          "400": {
            "description": "Missing or non-boolean `approved`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "No ticket with that id was found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "The ticket exists but is not in an approvable state (already decided / not awaiting approval).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Could not process the approval.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "x-amazon-apigateway-integration": {
          "type": "aws_proxy",
          "httpMethod": "POST",
          "passthroughBehavior": "when_no_match",
          "uri": "arn:aws:apigateway:us-east-1:lambda:path/2015-03-31/functions/arn:aws:lambda:us-east-1:123456789012:function:RelayApiStack-approve/invocations"
        }
      }
    },
    "/tickets/{ticket_id}/feedback": {
      "post": {
        "operationId": "submitFeedback",
        "summary": "Submit a 1-5 customer rating on the answer (Module 13).",
        "description": "The user-feedback loop (skill 5.1.3). Sets feedback_rating on the frozen TicketRecord (the field added by addition at Module 13) so a stream of low-rated answers becomes new failing cases for the golden set. Strict: `feedback_rating` MUST be a JSON integer in [1, 5] (a bool/float/string or out-of-range value is a 400, never silently clamped). No foundation-model call — a single relay-tickets round-trip.",
        "parameters": [
          {
            "name": "ticket_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedbackRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated TicketRecord carrying the new feedback_rating.",
            "headers": {
              "Access-Control-Allow-Origin": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketRecord"
                }
              }
            }
          },
          "400": {
            "description": "Missing / non-integer / out-of-range `feedback_rating`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "No ticket with that id was found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Could not record the feedback.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "x-amazon-apigateway-integration": {
          "type": "aws_proxy",
          "httpMethod": "POST",
          "passthroughBehavior": "when_no_match",
          "uri": "arn:aws:apigateway:us-east-1:lambda:path/2015-03-31/functions/arn:aws:lambda:us-east-1:123456789012:function:RelayApiStack-feedback/invocations"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateTicketRequest": {
        "type": "object",
        "required": [
          "customer_message"
        ],
        "properties": {
          "customer_message": {
            "type": "string",
            "minLength": 1,
            "description": "The customer's message. Required and non-empty."
          },
          "channel": {
            "type": "string",
            "enum": [
              "email",
              "chat"
            ],
            "description": "The channel the ticket arrived on. Defaults to email when omitted."
          },
          "ticket_id": {
            "type": "string",
            "description": "Optional caller-supplied id (generated when omitted). A supplied id makes the POST idempotent — the worker upserts."
          },
          "triage_intent": {
            "type": "string",
            "description": "Optional routing hint passed through to the agent."
          },
          "customer_id": {
            "type": "string",
            "description": "Optional routing hint passed through to the agent."
          },
          "session_id": {
            "type": "string",
            "description": "Optional routing hint passed through to the agent."
          }
        }
      },
      "CreateTicketResponse": {
        "type": "object",
        "required": [
          "ticket_id",
          "status"
        ],
        "properties": {
          "ticket_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "received"
            ]
          }
        }
      },
      "ApproveRequest": {
        "type": "object",
        "required": [
          "approved"
        ],
        "properties": {
          "approved": {
            "type": "boolean",
            "description": "true executes the refund (status -> answered); false abandons it and escalates (status -> escalated). Must be a JSON boolean."
          }
        }
      },
      "Triage": {
        "type": "object",
        "required": [
          "intent",
          "priority",
          "sentiment"
        ],
        "properties": {
          "intent": {
            "type": "string",
            "enum": [
              "billing",
              "technical",
              "account",
              "shipping",
              "other"
            ]
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "normal",
              "high",
              "urgent"
            ]
          },
          "sentiment": {
            "type": "string",
            "enum": [
              "negative",
              "neutral",
              "positive"
            ]
          }
        }
      },
      "Citation": {
        "type": "object",
        "required": [
          "source_uri",
          "snippet"
        ],
        "properties": {
          "source_uri": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          }
        }
      },
      "Answer": {
        "type": "object",
        "required": [
          "text",
          "citations",
          "grounded"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "citations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Citation"
            }
          },
          "grounded": {
            "type": "boolean"
          }
        }
      },
      "AgentAction": {
        "type": "object",
        "required": [
          "tool",
          "tool_input",
          "result"
        ],
        "properties": {
          "tool": {
            "type": "string",
            "description": "The canonical tool name: search_kb, lookup_order, or create_ticket."
          },
          "tool_input": {
            "type": "object"
          },
          "result": {
            "type": "string"
          },
          "approved": {
            "type": "boolean",
            "nullable": true,
            "description": "null = proposed, true = approved, false = rejected (effective from Module 8)."
          }
        }
      },
      "TicketRecord": {
        "type": "object",
        "required": [
          "ticket_id",
          "status",
          "triage",
          "answer",
          "actions",
          "escalated",
          "cost_cents",
          "feedback_rating",
          "updated_at"
        ],
        "properties": {
          "ticket_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "received",
              "triaged",
              "awaiting_approval",
              "answered",
              "escalated",
              "closed",
              "failed"
            ]
          },
          "triage": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/Triage"
              }
            ]
          },
          "answer": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/Answer"
              }
            ]
          },
          "actions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentAction"
            }
          },
          "escalated": {
            "type": "boolean"
          },
          "cost_cents": {
            "type": "number",
            "format": "float",
            "description": "Placeholder 0.0 at Module 7; really populated (summed token usage x the Module 3 per-tier price map) at Module 12."
          },
          "feedback_rating": {
            "type": "integer",
            "nullable": true,
            "minimum": 1,
            "maximum": 5,
            "description": "The customer's 1-5 rating of the answer, or null when none was left (added by addition at Module 13)."
          },
          "updated_at": {
            "type": "string",
            "description": "ISO-8601 timestamp of the last write."
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string",
            "description": "A caller-facing, actionable error message — never a stack trace."
          }
        }
      },
      "FeedbackRequest": {
        "type": "object",
        "required": [
          "feedback_rating"
        ],
        "properties": {
          "feedback_rating": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "A 1-5 rating of the answer (1 = bad, 5 = great). A thumbs-down/up UI maps to 1/5. Must be a JSON integer in range."
          }
        }
      }
    }
  }
}
